# FOIA Redaction Tool — Phase 1 configuration
# Copy to .env and adjust for your environment.

# SQLite database path (absolute or relative to process CWD).
FOIA_DB_PATH=./data/foia.db

# Directory where extracted attachments are stored.
FOIA_ATTACHMENT_DIR=./data/attachments

# Logging verbosity (DEBUG, INFO, WARNING, ERROR).
FOIA_LOG_LEVEL=INFO

# --- Phase 2: attachment processing + OCR ---

# Enable OCR for images and scanned PDFs. If tesseract is not available,
# processing falls back to text-layer extraction only.
FOIA_OCR_ENABLED=true
FOIA_OCR_LANG=eng
FOIA_OCR_DPI=200
# Optional absolute path to the tesseract executable. Leave blank to auto-resolve via PATH.
FOIA_TESSERACT_CMD=

# Enable LibreOffice-powered conversion of Office documents into PDF for extraction.
FOIA_OFFICE_ENABLED=true
# 'soffice' on Linux/macOS; on Windows use the full path to soffice.exe if not on PATH.
FOIA_LIBREOFFICE_CMD=soffice

# Timeout (seconds) for any single extraction subprocess (OCR or LibreOffice).
FOIA_EXTRACTION_TIMEOUT_S=180

# --- Phase 3: PII detection ---

# Path to the district YAML. See config/district.example.yaml.
FOIA_CONFIG_FILE=./config/district.yaml

# --- Phase 7: review UI ---

# Comma-separated CORS origins permitted to call the API. The Vite dev
# server defaults to http://localhost:5173.
FOIA_CORS_ORIGINS=http://localhost:5173

# --- Phase 8: PDF export ---

# Where /api/v1/exports writes production.pdf + redaction_log.csv.
FOIA_EXPORT_DIR=./data/exports

# --- Phase 9: audit log ---

# Default actor used by CLI invocations when --actor isn't passed and
# no FOIA_ACTOR env value is set, the actor falls back to cli:{username}.
# FOIA_ACTOR=ops-shared

# --- Phase 10: AI QA layer (optional) ---

# API key for the configured AI provider (OpenAI / Azure / Anthropic).
# Override the env-var name itself in district.yaml's ai.api_key_env if
# you want, but FOIA_AI_API_KEY is the default lookup.
# FOIA_AI_API_KEY=sk-...
